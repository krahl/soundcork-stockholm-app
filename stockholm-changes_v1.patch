index 0000000..b8e66ef
--- /dev/null
+++ b/stockholm/js/browser_http_proxy.js
@@ -0,0 +1,65 @@
+(function () {
+    if (typeof window === "undefined" || typeof window.jQuery === "undefined" || typeof window.URL === "undefined") {
+        return;
+    }
+
+    var PROXY_PATH = "/api/http-proxy";
+    var originalAjax = window.jQuery.ajax;
+
+    function resolveUrl(input) {
+        return new URL(input, window.location.href);
+    }
+
+    function shouldProxy(input) {
+        if (!input || typeof input !== "string") {
+            return false;
+        }
+
+        var target;
+        try {
+            target = resolveUrl(input);
+        } catch (error) {
+            return false;
+        }
+
+        if (target.protocol !== "http:" && target.protocol !== "https:") {
+            return false;
+        }
+
+        if (target.origin === window.location.origin) {
+            return false;
+        }
+
+        return true;
+    }
+
+    function proxiedUrl(input) {
+        var target = resolveUrl(input);
+        return PROXY_PATH + "?url=" + encodeURIComponent(target.href);
+    }
+
+    function rewriteAjaxArgs(url, options) {
+        if (typeof url === "string") {
+            var rewrittenUrl = shouldProxy(url) ? proxiedUrl(url) : url;
+            return options === undefined ? [rewrittenUrl] : [rewrittenUrl, options];
+        }
+
+        if (url && typeof url === "object" && typeof url.url === "string" && shouldProxy(url.url)) {
+            return [window.jQuery.extend({}, url, { url: proxiedUrl(url.url) }), options];
+        }
+
+        return [url, options];
+    }
+
+    window.jQuery.ajax = function (url, options) {
+        var rewrittenArgs = rewriteAjaxArgs(url, options);
+        return originalAjax.apply(this, rewrittenArgs);
+    };
+
+    window.StockholmBrowserHttpProxy = {
+        proxyUrl: function (input) {
+            return shouldProxy(input) ? proxiedUrl(input) : input;
+        },
+        shouldProxy: shouldProxy
+    };
+})();
diff --git a/stockholm/js/browser_native_bridge.js b/stockholm/js/browser_native_bridge.js
new file mode 100644
index 0000000..9e1d505
--- /dev/null
+++ b/stockholm/js/browser_native_bridge.js
@@ -0,0 +1,70 @@
+(function () {
+    if (typeof window === "undefined" || typeof window.Native !== "undefined") {
+        return;
+    }
+
+    var clientIdKey = "stockholmBridgeClientId";
+    var clientId = window.localStorage.getItem(clientIdKey);
+    if (!clientId) {
+        clientId = "stockholm-" + Date.now().toString(36) + "-" + Math.random().toString(36).slice(2);
+        window.localStorage.setItem(clientIdKey, clientId);
+    }
+
+    function appSend(jsonString) {
+        var payload = JSON.parse(jsonString);
+        switch (payload.method) {
+            case "reloadWebview":
+                if (payload.params && payload.params.url) {
+                    window.location.href = payload.params.url;
+                }
+                return;
+            case "openUrl":
+                if (payload.params && payload.params.url) {
+                    window.open(payload.params.url, "_blank", "noopener");
+                }
+                return;
+            case "openApp":
+                if (payload.params && payload.params.appUri) {
+                    window.open(payload.params.appUri, "_blank", "noopener");
+                    return;
+                }
+                if (payload.params && payload.params.fallbackURL) {
+                    window.open(payload.params.fallbackURL, "_blank", "noopener");
+                }
+                return;
+            case "log":
+                if (payload.params && payload.params.msg) {
+                    console.log(payload.params.msg);
+                }
+                return;
+            default:
+                break;
+        }
+
+        var xhr = new XMLHttpRequest();
+        xhr.open("POST", "/api/native/appSend", true);
+        xhr.setRequestHeader("Content-Type", "application/json");
+        xhr.setRequestHeader("X-Stockholm-Client-Id", clientId);
+        xhr.send(JSON.stringify(payload));
+    }
+
+    function runQueue() {
+        var xhr = new XMLHttpRequest();
+        xhr.open("GET", "/api/native/runQueue?clientId=" + encodeURIComponent(clientId), false);
+        xhr.setRequestHeader("X-Stockholm-Client-Id", clientId);
+        try {
+            xhr.send(null);
+        } catch (error) {
+            return JSON.stringify({ messages: null });
+        }
+        return xhr.status >= 200 && xhr.status < 300 ? xhr.responseText : JSON.stringify({ messages: null });
+    }
+
+    window.Native = {
+        appSend: appSend,
+        runQueue: runQueue,
+        unblock: function () {}
+    };
+
+    window.STOCKHOLM_NATIVE_POLL_INTERVAL = 1000;
+})();
