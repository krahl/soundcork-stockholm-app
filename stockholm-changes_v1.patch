diff --git a/stockholm/js/browser_http_proxy.js b/stockholm/js/browser_http_proxy.js
new file mode 100644
index 0000000..b8e66ef
--- /dev/null
+++ b/stockholm/js/browser_http_proxy.js
@@ -0,0 +1,65 @@
+(function () {
+    if (typeof window === "undefined" || typeof window.jQuery === "undefined" || typeof window.URL === "undefined") {
+        return;
+    }
+
+    var PROXY_PATH = "/api/http-proxy";
+    var originalAjax = window.jQuery.ajax;
+
+    function resolveUrl(input) {
+        return new URL(input, window.location.href);
+    }
+
+    function shouldProxy(input) {
+        if (!input || typeof input !== "string") {
+            return false;
+        }
+
+        var target;
+        try {
+            target = resolveUrl(input);
+        } catch (error) {
+            return false;
+        }
+
+        if (target.protocol !== "http:" && target.protocol !== "https:") {
+            return false;
+        }
+
+        if (target.origin === window.location.origin) {
+            return false;
+        }
+
+        return true;
+    }
+
+    function proxiedUrl(input) {
+        var target = resolveUrl(input);
+        return PROXY_PATH + "?url=" + encodeURIComponent(target.href);
+    }
+
+    function rewriteAjaxArgs(url, options) {
+        if (typeof url === "string") {
+            var rewrittenUrl = shouldProxy(url) ? proxiedUrl(url) : url;
+            return options === undefined ? [rewrittenUrl] : [rewrittenUrl, options];
+        }
+
+        if (url && typeof url === "object" && typeof url.url === "string" && shouldProxy(url.url)) {
+            return [window.jQuery.extend({}, url, { url: proxiedUrl(url.url) }), options];
+        }
+
+        return [url, options];
+    }
+
+    window.jQuery.ajax = function (url, options) {
+        var rewrittenArgs = rewriteAjaxArgs(url, options);
+        return originalAjax.apply(this, rewrittenArgs);
+    };
+
+    window.StockholmBrowserHttpProxy = {
+        proxyUrl: function (input) {
+            return shouldProxy(input) ? proxiedUrl(input) : input;
+        },
+        shouldProxy: shouldProxy
+    };
+})();
