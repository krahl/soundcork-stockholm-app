TZ=Europe/Berlin
BACKEND_BIND_IP=0.0.0.0
BACKEND_PORT=8088
BACKEND_URL=http://soundcork.local.example.com:8000
# For soundcork: set STREAMING_URL to BACKEND_URL + /marge (no trailing slash)
# For other backends (e.g. Bose-SoundTouch): omit STREAMING_URL, it defaults to BACKEND_URL
#STREAMING_URL=http://soundcork.local.example.com:8000/marge
# marge/ suffix is important if used against soundcork
AUTH_SERVICE_URL=http://soundcork.local.example.com:8000/marge/

# Optional: provide the Marge session values from your old SoundTouch state.
#MARGE_AUTH_TOKEN=
#MARGE_ACCOUNT_ID=

# Optional aliases for the same values
#margeAuthToken=
#margeAccountID=
