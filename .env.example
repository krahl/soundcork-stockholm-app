TZ=Europe/Berlin
BACKEND_BIND_IP=0.0.0.0
BACKEND_PORT=8088
BACKEND_URL=http://soundcork.local.example.com:8000
# Recommended for new installs. Existing installs can leave this unset to keep using one shared native-state.json session.
STOCKHOLM_CLIENT_STATE_MODE=per-browser
# Optional: defaults to BACKEND_URL/marge inside the container when unset.
# For other backends, set STREAMING_URL explicitly to the URL you need.
#STREAMING_URL=http://soundcork.local.example.com:8000/marge
# The trailing / is important and use marge/ suffix when used against soundcork!
AUTH_SERVICE_URL=http://soundcork.local.example.com:8000/marge/

# Optional: provide the Marge session values from your old SoundTouch state.
#MARGE_AUTH_TOKEN=
#MARGE_ACCOUNT_ID=

# Optional aliases for the same values
#margeAuthToken=
#margeAccountID=
