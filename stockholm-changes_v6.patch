@@ -4,8 +4,26 @@
     }
 
     var PROXY_PATH = "/api/http-proxy";
+    var CLIENT_ID_KEY = "stockholmBridgeClientId";
     var originalAjax = window.jQuery.ajax;
 
+    function readCookie(name) {
+        var prefix = name + "=";
+        var cookies = document.cookie ? document.cookie.split(";") : [];
+        for (var index = 0; index < cookies.length; index++) {
+            var cookie = cookies[index].trim();
+            if (cookie.indexOf(prefix) === 0) {
+                return decodeURIComponent(cookie.substring(prefix.length));
+            }
+        }
+        return null;
+    }
+
+    function clientId() {
+        var bootstrap = window.StockholmBrowserBootstrap || {};
+        return bootstrap.clientId || readCookie("stockholmClientId") || window.localStorage.getItem(CLIENT_ID_KEY);
+    }
+
     function resolveUrl(input) {
         return new URL(input, window.location.href);
     }
@@ -35,7 +53,9 @@
 
     function proxiedUrl(input) {
         var target = resolveUrl(input);
-        return PROXY_PATH + "?url=" + encodeURIComponent(target.href);
+        var resolvedClientId = clientId();
+        var url = PROXY_PATH + "?url=" + encodeURIComponent(target.href);
+        return resolvedClientId ? url + "&clientId=" + encodeURIComponent(resolvedClientId) : url;
     }
 
