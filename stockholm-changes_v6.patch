diff --git a/stockholm/js/app_comm.js b/stockholm/js/app_comm.js
index 875d6fe..94ddd9e 100644
--- a/stockholm/js/app_comm.js
+++ b/stockholm/js/app_comm.js
@@ -11,8 +11,26 @@ function AppComm() {
         }
 
         var proxyPath = "/api/http-proxy";
+        var clientIdKey = "stockholmBridgeClientId";
         var originalAjax = window.jQuery.ajax;
 
+        function readCookie(name) {
+            var prefix = name + "=";
+            var cookies = document.cookie ? document.cookie.split(";") : [];
+            for (var index = 0; index < cookies.length; index++) {
+                var cookie = cookies[index].trim();
+                if (cookie.indexOf(prefix) === 0) {
+                    return decodeURIComponent(cookie.substring(prefix.length));
+                }
+            }
+            return null;
+        }
+
+        function browserClientId() {
+            var bootstrap = window.StockholmBrowserBootstrap || {};
+            return bootstrap.clientId || readCookie("stockholmClientId") || window.localStorage.getItem(clientIdKey);
+        }
+
         function resolveUrl(input) {
             return new URL(input, window.location.href);
         }
@@ -33,7 +51,9 @@ function AppComm() {
         }
 
         function proxiedUrl(input) {
